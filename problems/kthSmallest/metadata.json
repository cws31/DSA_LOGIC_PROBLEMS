{
  "id": "kthSmallest",
  "title": "Kth Smallest Element in a BST",
  "difficulty": "Medium",
  "topic": "Tree",
  "methodName": "kthSmallest",
  "returnType": "int",
  "argumentTypes": ["TreeNode", "int"],
  "description": "Given the root of a binary search tree and an integer k, return the kth smallest value among all nodes in the tree.",
  "constraints": [
    "1 <= k <= number of nodes",
    "0 <= Node.val <= 10^4"
  ],
  "examples": [
    {
      "input": "root = [3,1,4,null,2], k = 1",
      "output": "1"
    },
    {
      "input": "root = [5,3,6,2,4,null,null,1], k = 3",
      "output": "3"
    }
  ]
}
